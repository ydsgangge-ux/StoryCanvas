# LLM 提供商 (deepseek|openai|claude|gemini|ollama|custom)
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_BASE_URL=https://api.anthropic.com

# Gemini (Google)
GEMINI_API_KEY=xxx
GEMINI_MODEL=gemini-1.5-pro

# Ollama (本地)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5

# 自定义 OpenAI 兼容 API
CUSTOM_BASE_URL=https://your-api-endpoint.com/v1
CUSTOM_API_KEY=sk-xxx
CUSTOM_MODEL=custom-model

# 服务配置
PORT=8767
DATABASE_PATH=./backend/data/storycanvas.db
STORY_CARDS_PATH=./backend/story_cards/cards.json

# 生成配置
DEFAULT_TEMPERATURE=0.8
AUDIT_TEMPERATURE=0.0
MAX_RETRIES=2
CHAPTER_WORD_TARGET=3000
